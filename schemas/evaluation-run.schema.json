{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://offeragent.dev/schemas/evaluation-run.schema.json",
  "title": "EvaluationRun",
  "type": "object",
  "required": ["id", "created_at", "input_snapshot", "report"],
  "properties": {
    "id": { "type": "string" },
    "created_at": { "type": "string" },
    "schema_version": { "type": "string" },
    "input_fingerprint": { "type": "string" },
    "cache_status": { "type": "string", "enum": ["hit", "miss", "stored"] },
    "cached_at": { "type": "string" },
    "restored_at": { "type": "string" },
    "provider": { "type": "string" },
    "model": { "type": "string" },
    "mode": { "type": "string", "enum": ["mock", "llm"] },
    "input_snapshot": {
      "type": "object",
      "properties": {
        "target_role": { "type": "string" },
        "resume": { "type": "string" },
        "job_description": { "type": "string" },
        "company_context": { "type": "string" },
        "candidate_stage": { "type": "string" },
        "target_level": { "type": "string" },
        "offer_constraints": { "type": "string" },
        "selected_skills": { "type": "array", "items": { "type": "string" } },
        "language": { "type": "string" }
      }
    },
    "evaluation_summary": {
      "type": "object",
      "properties": {
        "gate_result": { "type": "string" },
        "enter_sandbox": { "type": "boolean" },
        "matched_count": { "type": "number" },
        "total_requirements": { "type": "number" },
        "evidence_summary": { "type": "string" },
        "strong_evidence_count": { "type": "number" },
        "medium_evidence_count": { "type": "number" },
        "weak_or_missing_evidence_count": { "type": "number" },
        "next_validation_focus": { "type": "array", "items": { "type": "string" } },
        "offer_leverage_rating": { "type": "string" },
        "offer_leverage_summary": { "type": "string" },
        "feedback_status": { "type": ["object", "null"] }
      }
    },
    "requirement_matches": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "capability": { "type": "string" },
          "jd_evidence": { "type": "string" },
          "resume_evidence": { "type": "string" },
          "evidence_level": { "type": "number" },
          "evidence_level_label": { "type": "string" },
          "evidence_reason": { "type": "string" },
          "match_status": { "type": "string" },
          "is_missing": { "type": "boolean" },
          "verification_question": { "type": "string" }
        }
      }
    },
    "interview_questions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "lens": { "type": "string" },
          "capability": { "type": "string" },
          "question": { "type": "string" },
          "evidence_anchor": { "type": "string" },
          "jd_anchor": { "type": "string" },
          "evaluation_goal": { "type": "string" },
          "expected_signal": { "type": "string" },
          "adoption_status": { "type": "string" }
        }
      }
    },
    "offer_sandbox": {
      "type": "object",
      "properties": {
        "stage": { "type": "string" },
        "target_level": { "type": "string" },
        "readiness": { "type": "string" },
        "enter_sandbox": { "type": "boolean" },
        "negotiation_leverage": { "type": "string" },
        "leverage_detail": { "type": "string" },
        "risks": { "type": "array", "items": { "type": "string" } },
        "next_actions": { "type": "array", "items": { "type": "string" } }
      }
    },
    "structured_evaluation": {
      "type": "object",
      "description": "Deterministic JSON intermediate layer used before rendering reports, graphs, and offer state.",
      "properties": {
        "schema_version": { "type": "string" },
        "target_role": { "type": "string" },
        "language": { "type": "string" },
        "summary": { "type": "object" },
        "requirement_matches": { "type": "array", "items": { "type": "object" } },
        "interview_questions": { "type": "array", "items": { "type": "object" } },
        "offer_sandbox": { "type": "object" },
        "evidence": { "type": "array", "items": { "type": "object" } },
        "decision_basis": { "type": "object" },
        "feedback_status": { "type": ["object", "null"] }
      }
    },
    "role_capability_matrix": {
      "type": "object",
      "properties": {
        "role_id": { "type": "string" },
        "role_label": { "type": "string" },
        "source_kind": { "type": "string" },
        "version": { "type": "string" },
        "summary": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "capability": { "type": "string" },
              "match_status": { "type": "string" },
              "evidence_level": { "type": "number" },
              "evidence_level_label": { "type": "string" },
              "jd_anchor": { "type": "string" },
              "resume_anchor": { "type": "string" },
              "decision_path_ids": { "type": "array", "items": { "type": "string" } },
              "next_validation": { "type": "string" }
            }
          }
        }
      }
    },
    "skill_registry": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "version": { "type": "string" },
          "role_id": { "type": "string" },
          "role_label": { "type": "string" },
          "focus": { "type": "string" },
          "adoption_status": { "type": "string" },
          "priority": { "type": "number" },
          "audit": { "type": "object" }
        }
      }
    },
    "skill_selection_audit": {
      "type": "object",
      "properties": {
        "registry_version": { "type": "string" },
        "source_kind": { "type": "string" },
        "target_role": { "type": "string" },
        "selected_skills": { "type": "array", "items": { "type": "string" } },
        "version_history": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "skill_id": { "type": "string" },
              "version": { "type": "string" },
              "adoption_status": { "type": "string" }
            }
          }
        },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "skill_id": { "type": "string" },
              "version": { "type": "string" },
              "adoption_status": { "type": "string" },
              "selection_reason": { "type": "string" },
              "contribution_summary": { "type": "string" },
              "decision_path_ids": { "type": "array", "items": { "type": "string" } },
              "source_kind": { "type": "string" }
            }
          }
        }
      }
    },
    "virtual_panel": {
      "type": "array",
      "description": "VirtualPanel: MiroFish-inspired interviewer personas generated from JD, resume, role, and selected skills.",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "skill_id": { "type": "string" },
          "name": { "type": "string" },
          "role_label": { "type": "string" },
          "persona": { "type": "string" },
          "focus": { "type": "string" },
          "stance": { "type": "string", "enum": ["supportive", "opposing", "neutral", "observer"] },
          "activity_level": { "type": "number" },
          "influence_weight": { "type": "number" },
          "memory_scope": { "type": "object" },
          "audit": { "type": "object" }
        }
      }
    },
    "panel_discussion_rounds": {
      "type": "array",
      "description": "PanelDiscussionRound: lightweight simulated discussion turns among virtual interviewer personas.",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "stage": { "type": "string" },
          "topic": { "type": "string" },
          "turns": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "agent_id": { "type": "string" },
                "stance": { "type": "string" },
                "claim": { "type": "string" },
                "evidence_ids": { "type": "array", "items": { "type": "string" } },
                "question_ids": { "type": "array", "items": { "type": "string" } },
                "impact": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "moderator_summary": {
      "type": "object",
      "description": "ModeratorSummary: report-agent-style synthesis of panel consensus, disagreement, and offer impact.",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string" },
        "consensus": { "type": "string" },
        "disagreement_count": { "type": "number" },
        "support_count": { "type": "number" },
        "lead_agent_id": { "type": "string" },
        "final_recommendation": { "type": "string" },
        "offer_impact": { "type": "string" },
        "feedback_impact": { "type": "string" }
      }
    },
    "offer_simulation_run": { "$ref": "offer-simulation-run.schema.json" },
    "evidence_graph": { "$ref": "evidence-graph.schema.json" },
    "evidence_decision_paths": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "capability": { "type": "string" },
          "decision": { "type": "string" },
          "route": { "type": "array", "items": { "type": "string" } },
          "focus_node_id": { "type": "string" },
          "confidence": { "type": "number" },
          "source_kind": { "type": "string" }
        }
      }
    },
    "feedback_distillation": { "$ref": "feedback-distillation.schema.json" },
    "feedback_session_history": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "signature": { "type": "string" },
          "updated_at": { "type": "string" },
          "agreement": { "type": "string" },
          "question_use": { "type": "string" },
          "evidence_sufficiency": { "type": "string" },
          "risk_validation": { "type": "string" },
          "notes": { "type": "string" }
        }
      }
    },
    "human_feedback": {
      "type": "object",
      "properties": {
        "agreement": { "type": "string" },
        "question_use": { "type": "string" },
        "disagreement_reason": { "type": "string" },
        "evidence_sufficiency": { "type": "string" },
        "risk_validation": { "type": "string" },
        "notes": { "type": "string" },
        "updated_at": { "type": "string" }
      }
    },
    "report": { "type": "string" },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "source_type": { "type": "string" },
          "claim": { "type": "string" },
          "confidence": { "type": "number" },
          "capability": { "type": "string" },
          "evidence_level": { "type": "number" },
          "evidence_level_label": { "type": "string" },
          "source_excerpt": { "type": "string" },
          "jd_excerpt": { "type": "string" },
          "verification_question": { "type": "string" }
        }
      }
    }
  }
}
